# ── Supabase (required) ────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_EDGE_FUNCTION_NAME=make-server-0b1f4071
# Optional overrides when your API is not hosted at /functions/v1/<name>
# VITE_EDGE_FUNCTIONS_BASE_URL=https://your-project.supabase.co/functions/v1
# VITE_API_URL=https://api.example.com

# ── Google Maps (required for WaselMap) ────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Google OAuth (required for social sign-in) ─────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_SUPPORT_WHATSAPP_NUMBER=962790000000
VITE_SUPPORT_EMAIL=support@wasel.jo
VITE_SUPPORT_PHONE_NUMBER=962790000000
VITE_SUPPORT_SMS_NUMBER=962790000000
VITE_AUTH_CALLBACK_PATH=/app/auth/callback
VITE_ENABLE_TWO_FACTOR_AUTH=false
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_SMS_NOTIFICATIONS=true
VITE_ENABLE_WHATSAPP_NOTIFICATIONS=true

# ── Stripe (required for payments) ─────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Firebase (required for push notifications) ─────────────────
# Browser notifications use the Web Notifications API and the app service worker.
# No Firebase client environment variables are required for the current frontend flow.

# ── Sentry (optional — error monitoring) ───────────────────────
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ── App config ─────────────────────────────────────────────────
VITE_APP_URL=https://wasel14.online
VITE_APP_NAME=Wasel

# ── Feature flags (set to false in production) ─────────────────
VITE_ENABLE_DEMO_DATA=false
VITE_ENABLE_SYNTHETIC_TRIPS=false
# Production should leave this disabled so writes fail closed when the secure
# backend contract is unavailable. Enable only for controlled fallback drills.
VITE_ALLOW_DIRECT_SUPABASE_FALLBACK=false

# —— Edge function / delivery engine secrets (server-side only) ———————————————
# Set these in Supabase Edge Function secrets, not in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
COMMUNICATION_WORKER_SECRET=replace-with-a-long-random-secret
COMMUNICATION_WEBHOOK_TOKEN=replace-with-a-long-random-token
COMMUNICATION_MAX_ATTEMPTS=5
COMMUNICATION_PROCESS_INLINE=false

# Email provider (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Wasel <notifications@wasel14.online>
RESEND_REPLY_TO_EMAIL=support@wasel14.online

# Email provider fallback (SendGrid)
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=notifications@wasel14.online

# SMS / WhatsApp provider (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_SMS_FROM=+962790000000
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
